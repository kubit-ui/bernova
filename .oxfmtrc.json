{
  "semi": true,
  "single_quote": true,
  "trailing_comma": "all",
  "print_width": 100,
  "tab_width": 2,
  "use_tabs": false,
  "bracket_spacing": true,
  "arrow_parens": "always",
  "end_of_line": "lf",
  "ignore": [
    "dist",
    "node_modules",
    "coverage",
    "types",
    ".changeset"
  ]
}
