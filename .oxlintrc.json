{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": {
    "node": true,
    "es2024": true
  },
  "globals": {
    "afterAll": "readonly",
    "afterEach": "readonly",
    "beforeAll": "readonly",
    "beforeEach": "readonly",
    "describe": "readonly",
    "expect": "readonly",
    "it": "readonly",
    "test": "readonly",
    "vi": "readonly"
  },
  "rules": {
    "complexity": "off"
  },
  "ignorePatterns": [
    "dist",
    "node_modules",
    "coverage",
    "types",
    "*.config.*",
    ".changeset"
  ]
}
